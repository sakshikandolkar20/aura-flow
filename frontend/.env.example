# Frontend API base URL
# Local development (backend running on port 5000):
# VITE_API_URL=http://127.0.0.1:5000
# VITE_API_BASE_URL=http://127.0.0.1:5000
#
# Production options:
# 1) Same domain as backend serverless: leave unset
# 2) Separate backend deployment: set full backend origin
# VITE_API_URL=https://your-backend-domain.example
